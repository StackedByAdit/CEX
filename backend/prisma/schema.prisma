// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum AssetType {
  INR
  STOCK
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String

  orders   Order[]
  balances Balance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stock {
  id     String @id @default(uuid())
  title  String
  symbol String @unique

  orders   Order[]
  balances Balance[]

  createdAt DateTime @default(now())

  fills Fill[]
}

model Order {
  id String @id @default(uuid())

  userId  String
  stockId String

  side   OrderSide
  type   OrderType
  status OrderStatus @default(PENDING)

  price          Float?
  quantity       Float
  filledQuantity Float  @default(0)

  user  User  @relation(fields: [userId], references: [id])
  stock Stock @relation(fields: [stockId], references: [id])

  buyFills  Fill[] @relation("BuyOrder")
  sellFills Fill[] @relation("SellOrder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fill {
  id String @id @default(uuid())

  stockId String

  buyOrderId  String
  sellOrderId String

  price    Float
  quantity Float

  buyOrder  Order @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrder Order @relation("SellOrder", fields: [sellOrderId], references: [id])

  stock Stock @relation(fields: [stockId], references: [id])

  createdAt DateTime @default(now())
}

model Balance {
  id String @id @default(uuid())

  userId  String
  stockId String?

  assetType AssetType

  available Float @default(0)
  locked    Float @default(0)

  user  User   @relation(fields: [userId], references: [id])
  stock Stock? @relation(fields: [stockId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
